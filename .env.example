# Core app settings
FLASK_DEBUG=false
PORT=5001
NBA_SEASON_START_YEAR=2025
REQUEST_TIMEOUT_SECONDS=15

# Optional RapidAPI setup
RAPIDAPI_KEY=
RAPIDAPI_HOST=api-nba-v1.p.rapidapi.com

# Optional prop providers
PROP_PROFESSOR_API_KEY=
PROP_PROFESSOR_BASE_URL=https://api.propprofessor.com

# Underdog Pick'em setup
UNDERDOG_API_BASE=https://api.underdogfantasy.com
UNDERDOG_SEARCH_PATH=/v2/pickem_search/search_results
UNDERDOG_LINES_PATH=/v1/lobbies/content/lines
UNDERDOG_PRODUCT=fantasy
UNDERDOG_PRODUCT_EXPERIENCE_ID=018e1234-5678-9abc-def0-123456789002
UNDERDOG_SPORT_ID=NBA
UNDERDOG_STATE_CONFIG_ID=60267d4a-6aeb-4ccc-b5c5-344b9a5466db
UNDERDOG_INCLUDE_LIVE=true
UNDERDOG_SHOW_MASS_OPTION_MARKETS=false
UNDERDOG_USER_AGENT=Mozilla/5.0

# ParlayPlay setup
PARLAYPLAY_API_BASE=https://parlayplay.io
PARLAYPLAY_SEARCH_PATH=/api/v1/crossgame/search/
PARLAYPLAY_PERIOD=FG
PARLAYPLAY_ORIGIN=https://parlayplay.io
PARLAYPLAY_REFERER=https://parlayplay.io/
PARLAYPLAY_USER_AGENT=Mozilla/5.0
PARLAYPLAY_ACCEPT_LANGUAGE=en-US,en;q=0.9
PARLAYPLAY_COOKIE=
